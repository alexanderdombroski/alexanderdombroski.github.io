---
import BaseHead from '../components/base/Head.astro';

type Props = {
  title: string;
  description: string;
};

const { title, description } = Astro.props;
---

<html lang="en">
  <head>
    <BaseHead title={title} description={description} />
  </head>
  <body>
    <slot />
  </body>
</html>

<style>
  body {
    height: 100vh;
    align-content: center;
  }
</style>
