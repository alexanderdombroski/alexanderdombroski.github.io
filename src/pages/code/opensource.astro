---
import { Octokit } from 'octokit';
import { getSecret } from 'astro:env/server';

const octokit = new Octokit({
  auth: getSecret('GITHUB_TOKEN'),
});

type Contribution = {
  owner: string;
  repo: string;
  id: number;
};

const ASTRO = { owner: 'withastro', repo: 'astro' };
const VS_CODE = { owner: 'microsoft', repo: 'vscode' };

const issues: Contribution[] = [
  { ...VS_CODE, id: 318402 },
  { ...VS_CODE, id: 307819 },
];

const prs: Contribution[] = [
  { ...VS_CODE, id: 318104 },
  { ...ASTRO, id: 16762 },
  { ...ASTRO, id: 16128 },
  { ...ASTRO, id: 15943 },
  { ...VS_CODE, id: 302322 },
  {
    owner: 'material-extensions',
    repo: 'vscode-material-icon-theme',
    id: 3269,
  },
];

const fetchPrData = async ({ owner, repo, id }: Contribution) => {
  const { data } = await octokit.request(
    'GET /repos/{owner}/{repo}/pulls/{pull_number}',
    {
      owner,
      repo,
      pull_number: id,
    },
  );
  return data;
};
const fetchIssueData = async ({ owner, repo, id }: Contribution) => {
  const { data } = await octokit.request(
    'GET /repos/{owner}/{repo}/issues/{issue_number}',
    {
      owner,
      repo,
      issue_number: id,
    },
  );
  return data;
};

const prData = await Promise.all(prs.map(fetchPrData));
const issueData = await Promise.all(issues.map(fetchIssueData));
---

<!-- https://astro.badg.es/contributor/alexanderdombroski/ -->
<h1>Open Source Contributions</h1>

<p>A history of interactions with the open source world</p>

<h2>Pull Requests</h2>
<div class="grid">
  {
    prData.map((pr) => {
      const status = pr.merged_at
        ? 'merged'
        : pr.state === 'closed'
          ? 'closed'
          : 'open';

      return (
        <a href={pr.html_url} target="_blank">
          <div class="card">
            <div class="repo">{pr.base.repo.full_name}</div>

            <div class="title">{pr.title}</div>

            <div class="meta">
              <span>#{pr.number}</span>

              <span class={`badge ${status}`}>{status}</span>
            </div>
          </div>
        </a>
      );
    })
  }
</div>

<h2>Issues</h2>
<div class="grid">
  {
    issueData.map((issue) => {
      const status = issue.state === 'closed' ? 'closed' : 'open';

      return (
        <a href={issue.html_url} target="_blank" rel="noreferrer">
          <div class="card">
            <div class="repo">
              {issue.repository_url.split('/').slice(-2).join('/')}
            </div>

            <div class="title">{issue.title}</div>

            <div class="meta">
              <span>#{issue.number}</span>

              <span class={`badge ${status}`}>{status}</span>
            </div>
          </div>
        </a>
      );
    })
  }
</div>

<style>
  h2 {
    margin-top: 2rem;
    margin-bottom: 1rem;
    font-size: 1.35rem;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
    margin-top: 2rem;
  }

  .card {
    border: 1px solid #e5e7eb;
    border-radius: 14px;
    padding: 1.25rem;
    background: white;
    transition: all 0.2s ease;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .card:hover {
    transform: translateY(-4px);
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.08);
  }

  .repo {
    font-size: 0.85rem;
    color: #6b7280;
    font-weight: 500;
  }

  .title {
    font-size: 1.05rem;
    font-weight: 600;
    line-height: 1.4;
  }

  .meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: auto;
    font-size: 0.8rem;
  }

  .badge {
    padding: 0.25rem 0.5rem;
    border-radius: 999px;
    font-weight: 500;
  }

  .open {
    background: #ecfeff;
    color: #0891b2;
  }

  .merged {
    background: #ecfdf5;
    color: #059669;
  }

  .closed {
    background: #fef2f2;
    color: #dc2626;
  }

  a {
    text-decoration: none;
    color: inherit;
  }
</style>
