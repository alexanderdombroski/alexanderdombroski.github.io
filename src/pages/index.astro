---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../src/consts';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main>
      <div class="intro">
        <div>
          <h1>Hi, I'm Alex Dombroski</h1>
          <p>
            I'll add some cool projects to this site later, but for now,
            checkout my <a href="https://github.com/alexanderdombroski"
              >Github</a
            >
          </p>
        </div>
        <figure>
          <img src="/images/alexd.png" alt="Alex Dombroski" />
        </figure>
      </div>
    </main>
    <Footer />
  </body>
</html>

<style>
  .intro {
    display: flex;
    flex-direction: row;
    justify-content: space-evenly;
    align-items: center;
    gap: 1rem;
  }
  figure {
    margin: 0;
    /* border-radius: 50%; */
    overflow: hidden;
    max-width: 400px;
    max-height: 400px;
    box-shadow: 3px 3px 10px;
    display: flex;
    justify-content: center;
  }
  img {
    /* transform: translate(-50%); */
    max-width: none;
    height: unset;
  }
</style>
